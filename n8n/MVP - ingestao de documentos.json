    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item) => {\n  const embedding = item.json.data?.[0]?.embedding;\n\n  if (!embedding) {\n    throw new Error(\"Embedding não encontrado na resposta da OpenAI.\");\n  }\n\n  return {\n    json: {\n      documentName: item.json.documentName,\n      pageNumber: item.json.pageNumber,\n      content: item.json.content,\n      embedding: `[${embedding.join(\",\")}]`,\n    },\n  };\n});"
      },
